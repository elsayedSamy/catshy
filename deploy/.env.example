# ═══════════════════════════════════════════════════
# CATSHY Environment Configuration
# Copy to .env and fill in your values
# ═══════════════════════════════════════════════════

# Database (PostgreSQL)
DATABASE_URL=postgresql+asyncpg://catshy:CHANGE_ME@localhost:5432/catshy
DATABASE_URL_SYNC=postgresql://catshy:CHANGE_ME@localhost:5432/catshy

# Redis
REDIS_URL=redis://:CHANGE_ME@localhost:6379/0
CELERY_BROKER_URL=redis://:CHANGE_ME@localhost:6379/1
CELERY_RESULT_BACKEND=redis://:CHANGE_ME@localhost:6379/2

# Authentication
JWT_SECRET=CHANGE_ME_USE_openssl_rand_hex_64
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS (JSON array of allowed origins)
CORS_ORIGINS=["http://localhost","http://127.0.0.1"]

# SSRF Protection
SSRF_DENY_PRIVATE=true
SSRF_TIMEOUT=15
SSRF_ALLOWLIST=[]

# Feature Flags
ENABLE_TOR=false

# Reports
REPORT_COMPANY_NAME=CATSHY
